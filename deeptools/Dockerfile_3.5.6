# deeptools Dockerfile for WILDS Docker Library
# deepTools: tools for exploring deep sequencing data
FROM condaforge/miniforge3:24.7.1-2

# Adding labels for the GitHub Container Registry following WILDS standards
LABEL org.opencontainers.image.title="deeptools"
LABEL org.opencontainers.image.description="Docker image for deepTools in Fred Hutch OCDO's WILDS"
LABEL org.opencontainers.image.version="3.5.6"
LABEL org.opencontainers.image.authors="wilds@fredhutch.org"
LABEL org.opencontainers.image.url=https://ocdo.fredhutch.org/
LABEL org.opencontainers.image.documentation=https://getwilds.org/
LABEL org.opencontainers.image.source=https://github.com/getwilds/wilds-docker-library
LABEL org.opencontainers.image.licenses=MIT

# Set the shell option to fail if any command in a pipe fails
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Install deeptools via bioconda with pinned version
RUN mamba install -y -c bioconda -c conda-forge \
  deeptools=3.5.6 \
  && mamba clean -afy

# Smoke test to verify deeptools is installed correctly
RUN deeptools --version

# Set working directory
WORKDIR /data
