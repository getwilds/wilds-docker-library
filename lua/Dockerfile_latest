# Using the Ubuntu base image
FROM ubuntu:24.04

# Adding labels for the GitHub Container Registry
LABEL org.opencontainers.image.title="lua"
LABEL org.opencontainers.image.description="Docker image for Lua (with libraries needed to run Lmod) in Fred Hutch OCDO's WILDS"
LABEL org.opencontainers.image.version="latest"
LABEL org.opencontainers.image.authors="wilds@fredhutch.org"
LABEL org.opencontainers.image.url=https://ocdo.fredhutch.org/
LABEL org.opencontainers.image.documentation=https://getwilds.org/
LABEL org.opencontainers.image.source=https://github.com/getwilds/wilds-docker-library
LABEL org.opencontainers.image.licenses=MIT

# Set the shell option to fail if any command in a pipe fails
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ENV DEBIAN_FRONTEND=noninteractive

# Installing Lua 5.4 along with the Lua libraries Lmod expects at runtime
# (luaposix and luafilesystem). Lmod itself is provided by the host HPC.
RUN apt-get update \
  && LUA_VERSION=$(apt-cache policy lua5.4 | grep Candidate | awk '{print $2}') \
  && LIBLUA_VERSION=$(apt-cache policy liblua5.4-dev | grep Candidate | awk '{print $2}') \
  && LUAPOSIX_VERSION=$(apt-cache policy lua-posix | grep Candidate | awk '{print $2}') \
  && LUAFS_VERSION=$(apt-cache policy lua-filesystem | grep Candidate | awk '{print $2}') \
  && CA_VERSION=$(apt-cache policy ca-certificates | grep Candidate | awk '{print $2}') \
  && apt-get install -y --no-install-recommends \
  lua5.4="${LUA_VERSION}" \
  liblua5.4-dev="${LIBLUA_VERSION}" \
  lua-posix="${LUAPOSIX_VERSION}" \
  lua-filesystem="${LUAFS_VERSION}" \
  ca-certificates="${CA_VERSION}" \
  && ln -sf /usr/bin/lua5.4 /usr/bin/lua \
  && ln -sf /usr/bin/luac5.4 /usr/bin/luac \
  && rm -rf /var/lib/apt/lists/*

# Smoke test to verify Lua and the Lmod-required libraries work
RUN lua -v \
  && lua -e "require('posix'); require('lfs'); print('lua + posix + lfs OK')"
