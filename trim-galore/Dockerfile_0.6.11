# trim-galore Dockerfile for WILDS Docker Library
# Trim Galore: a wrapper around Cutadapt and FastQC for adapter/quality trimming
FROM condaforge/miniforge3:24.7.1-2

# Adding labels for the GitHub Container Registry following WILDS standards
LABEL org.opencontainers.image.title="trim-galore"
LABEL org.opencontainers.image.description="Docker image for Trim Galore in Fred Hutch OCDO's WILDS"
LABEL org.opencontainers.image.version="0.6.11"
LABEL org.opencontainers.image.authors="wilds@fredhutch.org"
LABEL org.opencontainers.image.url=https://ocdo.fredhutch.org/
LABEL org.opencontainers.image.documentation=https://getwilds.org/
LABEL org.opencontainers.image.source=https://github.com/getwilds/wilds-docker-library
LABEL org.opencontainers.image.licenses=MIT

# Set the shell option to fail if any command in a pipe fails
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Install Trim Galore via bioconda with pinned version
# This also installs Cutadapt, FastQC, and pigz as dependencies
RUN mamba install -y -c bioconda -c conda-forge \
  trim-galore=0.6.11 \
  && mamba clean -afy

# Smoke test to verify Trim Galore and key dependencies are installed correctly
RUN trim_galore --version && cutadapt --version && fastqc --version

# Set working directory
WORKDIR /data
