# fastp Dockerfile for WILDS Docker Library
# fastp: an ultra-fast all-in-one FASTQ preprocessor
FROM condaforge/miniforge3:24.7.1-2

# Adding labels for the GitHub Container Registry following WILDS standards
LABEL org.opencontainers.image.title="fastp"
LABEL org.opencontainers.image.description="Docker image for fastp in Fred Hutch OCDO's WILDS"
LABEL org.opencontainers.image.version="1.1.0"
LABEL org.opencontainers.image.authors="wilds@fredhutch.org"
LABEL org.opencontainers.image.url=https://ocdo.fredhutch.org/
LABEL org.opencontainers.image.documentation=https://getwilds.org/
LABEL org.opencontainers.image.source=https://github.com/getwilds/wilds-docker-library
LABEL org.opencontainers.image.licenses=MIT

# Set the shell option to fail if any command in a pipe fails
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# Install fastp via bioconda with pinned version
RUN mamba install -y -c bioconda -c conda-forge \
  fastp=1.1.0 \
  && mamba clean -afy

# Smoke test to verify fastp is installed correctly
RUN fastp --version

# Set working directory
WORKDIR /data
